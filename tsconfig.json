{
  "compilerOptions": {
    "target": "ES2020",
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "strict": true,
    "lib": [
      "esnext"
    ],
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}